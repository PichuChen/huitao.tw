<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>手繪陶瓷刮痧板｜慧陶香坊</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@300;400;600;700&family=Noto+Sans+TC:wght@300;400;500&display=swap" rel="stylesheet">
<style is:global>
:root{--gold:#c9a84c;--gold-light:#e2c97e;--gold-pale:#f5e9c8;--cream:#faf7f0;--parchment:#f0e8d5;--ink:#1a1612;--ink-soft:#2e2620;--red:#7a2020;--red-light:#9b3030;--gray-ink:#8c8278;--border-gold:rgba(201,168,76,0.3);--serif:'Noto Serif TC',serif;--sans:'Noto Sans TC',sans-serif;}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--cream);color:var(--ink);font-family:var(--serif);overflow-x:hidden}
nav{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(250,247,240,0.97);border-bottom:1px solid var(--border-gold);backdrop-filter:blur(12px);display:flex;align-items:center;justify-content:space-between;padding:0 3rem;height:68px;}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.nav-emblem{width:36px;height:36px;border:1.5px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1rem;color:var(--gold);font-weight:700;}
.nav-brand{font-size:1.05rem;font-weight:700;color:var(--gold);letter-spacing:0.15em;}
.nav-back{font-family:var(--sans);font-size:0.78rem;color:var(--gray-ink);letter-spacing:0.15em;text-decoration:none;transition:color 0.3s;}
.nav-back:hover{color:var(--gold);}
.hero{padding:8rem 2rem 4rem;background:var(--parchment);position:relative;text-align:center;}
.hero::before,.hero::after{content:'';position:absolute;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--gold),transparent);}
.hero::before{top:68px;}.hero::after{bottom:0;}
.hero-eyebrow{font-family:var(--sans);font-size:0.65rem;letter-spacing:0.55em;color:var(--gold);text-transform:uppercase;margin-bottom:0.8rem;display:block;}
.hero-title{font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:700;letter-spacing:0.2em;color:var(--ink);margin-bottom:0.5rem;}
.hero-rule{display:flex;align-items:center;justify-content:center;gap:0.7rem;margin:1rem 0;}
.hero-rule .rl{height:1px;background:var(--gold);width:55px;}
.hero-rule .dot{width:5px;height:5px;border-radius:50%;background:var(--gold);}
.hero-sub{font-family:var(--sans);font-size:0.88rem;font-weight:300;color:var(--gray-ink);letter-spacing:0.12em;line-height:2;}
.hero-artist{margin-top:1.5rem;display:inline-flex;align-items:center;gap:12px;padding:0.7rem 1.5rem;border:1px solid var(--border-gold);}
.hero-artist-name{font-family:var(--serif);font-size:0.85rem;font-weight:600;color:var(--ink);letter-spacing:0.2em;}
.hero-artist-sub{font-family:var(--sans);font-size:0.68rem;color:var(--gold);letter-spacing:0.12em;margin-top:2px;}
.filter-section{background:var(--cream);border-bottom:1px solid var(--border-gold);padding:1rem 2rem;display:flex;align-items:center;justify-content:center;gap:0.8rem;flex-wrap:wrap;position:sticky;top:68px;z-index:100;}
.filter-label{font-family:var(--sans);font-size:0.62rem;color:var(--gold);letter-spacing:0.4em;text-transform:uppercase;}
.fb{font-family:var(--sans);font-size:0.72rem;font-weight:300;border:1px solid var(--border-gold);background:transparent;color:var(--gray-ink);padding:0.38rem 1.1rem;cursor:pointer;letter-spacing:0.18em;transition:all 0.3s;}
.fb:hover,.fb.active{background:var(--gold);color:var(--ink);border-color:var(--gold);}
.shop-section{padding:4rem 2rem 7rem;}
.sec-wrap{max-width:1200px;margin:0 auto;}
.sec-info{display:flex;justify-content:space-between;align-items:center;margin-bottom:2.5rem;padding-bottom:1rem;border-bottom:1px solid var(--border-gold);}
.sec-title-sm{font-family:var(--serif);font-size:0.82rem;font-weight:600;letter-spacing:0.3em;color:var(--ink);}
.sec-count{font-family:var(--sans);font-size:0.72rem;color:var(--gold);letter-spacing:0.2em;}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1.8rem;}
.card{background:var(--cream);border:1px solid var(--border-gold);display:flex;flex-direction:column;overflow:hidden;cursor:pointer;transition:transform 0.4s,box-shadow 0.4s;}
.card:hover{transform:translateY(-8px);box-shadow:0 24px 50px rgba(28,20,8,0.12);}
.card-img-wrap{position:relative;overflow:hidden;aspect-ratio:3/4;background:var(--parchment);}
.card-img{width:100%;height:100%;object-fit:cover;transition:transform 0.6s;display:block;}
.card:hover .card-img{transform:scale(1.06);}
.card-overlay{position:absolute;inset:0;background:rgba(26,22,18,0.55);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.4s;}
.card:hover .card-overlay{opacity:1;}
.card-overlay span{color:var(--gold-pale);font-family:var(--sans);font-size:0.72rem;letter-spacing:0.3em;border:1px solid var(--gold);padding:0.5rem 1.3rem;}
.card-seal{position:absolute;top:10px;right:10px;font-family:var(--serif);font-size:10px;font-weight:700;background:var(--red);color:var(--gold-pale);width:30px;height:30px;display:flex;align-items:center;justify-content:center;letter-spacing:1px;}
.card-tassel-badge{position:absolute;top:10px;left:10px;font-family:var(--sans);font-size:9px;background:rgba(250,247,240,0.92);color:var(--red);border:1px solid rgba(122,32,32,0.25);padding:2px 7px;letter-spacing:1px;}
.card-body{padding:1.1rem 1.2rem;flex:1;}
.card-cat{font-family:var(--sans);font-size:0.58rem;color:var(--gold);letter-spacing:0.4em;text-transform:uppercase;margin-bottom:0.35rem;}
.card-name{font-size:0.95rem;font-weight:600;letter-spacing:0.1em;color:var(--ink);margin-bottom:0.25rem;}
.card-code{font-family:var(--sans);font-size:0.62rem;color:var(--gray-ink);letter-spacing:0.2em;}
.card-footer{padding:0.85rem 1.2rem;border-top:1px solid var(--border-gold);display:flex;align-items:center;justify-content:space-between;}
.card-price{font-family:var(--serif);font-size:0.88rem;font-weight:600;color:var(--red);}
.card-btn{font-family:var(--sans);font-size:0.65rem;color:var(--gold);letter-spacing:0.2em;transition:letter-spacing 0.3s;}
.card:hover .card-btn{letter-spacing:0.3em;}
.overlay{display:none;position:fixed;inset:0;background:rgba(26,22,18,0.75);z-index:999;align-items:center;justify-content:center;padding:1rem;backdrop-filter:blur(4px);}
.overlay.open{display:flex;}
.modal{background:var(--cream);border:1px solid var(--border-gold);width:100%;max-width:660px;max-height:90vh;overflow-y:auto;animation:mIn 0.3s ease;}
@keyframes mIn{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}
.m-top{position:sticky;top:0;z-index:5;background:#0c0a07;padding:0.8rem 1.1rem 0.8rem 1.75rem;display:flex;justify-content:space-between;align-items:center;}
.m-top-b{font-family:var(--serif);font-size:0.88rem;font-weight:700;color:var(--gold);letter-spacing:0.3em;}
.m-top-e{font-family:var(--sans);font-size:0.62rem;color:rgba(201,168,76,0.5);letter-spacing:0.3em;}
.m-top-actions{display:flex;align-items:center;gap:1rem;}
.m-top-close{width:32px;height:32px;border:1px solid rgba(201,168,76,.45);background:transparent;color:var(--gold);font-family:var(--sans);font-size:1.2rem;line-height:1;cursor:pointer;transition:background .2s,color .2s;}
.m-top-close:hover{background:var(--gold);color:#0c0a07;}
.m-photos{display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid var(--border-gold);}
.m-photo{display:flex;flex-direction:column;align-items:center;padding:1.5rem 1rem 1.2rem;gap:0.6rem;}
.m-photo:first-child{border-right:1px solid var(--border-gold);}
.m-photo-frame{width:150px;height:190px;overflow:hidden;border:1px solid var(--border-gold);}
.m-photo-frame img{width:100%;height:100%;object-fit:cover;display:block;}
.m-photo-label{font-family:var(--sans);font-size:0.58rem;color:var(--gold);letter-spacing:0.4em;text-transform:uppercase;}
.m-photo-note{font-family:var(--sans);font-size:0.65rem;color:var(--gray-ink);letter-spacing:0.1em;text-align:center;}
.m-body{padding:1.5rem 1.75rem;}
.m-code{font-family:var(--sans);font-size:0.6rem;color:var(--gold);letter-spacing:0.4em;margin-bottom:4px;}
.m-title-row{display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;margin-bottom:4px;}
.m-title{font-size:1.4rem;font-weight:700;color:var(--ink);letter-spacing:0.2em;}
.m-pb{text-align:right;flex-shrink:0;}
.m-pl{font-family:var(--sans);font-size:0.58rem;color:var(--gray-ink);letter-spacing:0.2em;margin-bottom:2px;}
.m-pv{font-family:var(--serif);font-size:1.05rem;font-weight:700;color:var(--red);}
.m-pn{font-family:var(--sans);font-size:0.58rem;color:var(--gray-ink);margin-top:2px;}
.m-sub{font-family:var(--sans);font-size:0.73rem;color:var(--gray-ink);letter-spacing:0.12em;margin-bottom:1rem;}
.m-tassel{display:inline-flex;align-items:center;gap:6px;border:1px solid rgba(122,32,32,0.25);padding:4px 12px;margin-bottom:1rem;font-family:var(--sans);font-size:0.68rem;color:var(--red-light);letter-spacing:0.1em;}
.m-artist{display:flex;align-items:center;gap:12px;background:var(--parchment);padding:0.9rem 1.2rem;border-left:3px solid var(--gold);margin-bottom:1.2rem;}
.m-av{width:34px;height:34px;border-radius:50%;border:1.5px solid var(--gold);display:flex;align-items:center;justify-content:center;font-size:0.85rem;font-weight:700;color:var(--gold);flex-shrink:0;}
.m-al{font-family:var(--sans);font-size:0.58rem;color:var(--gold);letter-spacing:0.3em;margin-bottom:2px;}
.m-an{font-family:var(--serif);font-size:0.88rem;font-weight:600;color:var(--ink);letter-spacing:0.15em;}
.m-as{font-family:var(--sans);font-size:0.62rem;color:var(--gray-ink);margin-top:1px;}
.m-con{background:var(--parchment);padding:1.2rem 1.4rem;border-left:3px solid var(--gold);margin-bottom:1.2rem;position:relative;overflow:hidden;}
.m-cd{position:absolute;top:-0.5rem;right:0.8rem;font-family:var(--serif);font-size:4rem;color:var(--gold);opacity:0.08;}
.m-cl{font-family:var(--sans);font-size:0.58rem;color:var(--gold);letter-spacing:0.4em;text-transform:uppercase;margin-bottom:7px;}
.m-ct{font-size:0.92rem;font-weight:600;color:var(--ink);letter-spacing:0.18em;margin-bottom:8px;}
.m-cx{font-family:var(--sans);font-size:0.76rem;font-weight:300;color:var(--ink-soft);line-height:2.2;}
.m-det{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
.m-sl{font-family:var(--sans);font-size:0.58rem;color:var(--gold);letter-spacing:0.4em;text-transform:uppercase;margin-bottom:0.6rem;padding-bottom:0.4rem;border-bottom:1px solid var(--border-gold);}
.m-sps{display:flex;flex-direction:column;gap:3px;}
.m-sr{display:flex;justify-content:space-between;padding:4px 8px;background:var(--parchment);}
.m-sk{font-family:var(--sans);font-size:0.65rem;color:var(--gray-ink);}
.m-sv{font-family:var(--sans);font-size:0.65rem;color:var(--ink);font-weight:500;}
.m-tags{display:flex;flex-wrap:wrap;gap:4px;}
.m-tag{font-family:var(--sans);font-size:0.6rem;color:var(--red);border:1px solid rgba(122,32,32,0.22);padding:2px 8px;letter-spacing:0.08em;}
.m-foot{padding:1rem 1.75rem;background:#0c0a07;display:flex;justify-content:space-between;align-items:center;margin-top:1.5rem;}
.m-fb{font-family:var(--serif);font-size:0.85rem;font-weight:700;color:var(--gold);letter-spacing:0.3em;}
.m-fn{font-family:var(--sans);font-size:0.6rem;color:rgba(201,168,76,0.45);letter-spacing:0.1em;}
.m-fs{font-family:var(--serif);font-size:0.85rem;font-weight:700;background:var(--red);color:var(--gold-pale);width:40px;height:40px;display:flex;align-items:center;justify-content:center;letter-spacing:1px;}
.m-close{display:block;width:100%;padding:0.75rem;background:transparent;border:none;border-top:1px solid var(--border-gold);font-family:var(--sans);font-size:0.7rem;color:var(--gold);letter-spacing:0.3em;cursor:pointer;text-align:center;transition:background 0.3s;}
.m-close:hover{background:var(--parchment);}
footer{background:#0c0a07;padding:3rem 2rem;text-align:center;border-top:1px solid rgba(201,168,76,0.15);}
.f-brand{font-size:1rem;font-weight:700;color:var(--gold);letter-spacing:0.3em;margin-bottom:0.5rem;}
.f-note{font-family:var(--sans);font-size:0.68rem;color:rgba(201,168,76,0.4);letter-spacing:0.18em;line-height:2;}
.f-back{display:inline-block;margin-top:1.5rem;font-family:var(--sans);font-size:0.7rem;color:rgba(201,168,76,0.5);letter-spacing:0.25em;text-decoration:none;border:1px solid rgba(201,168,76,0.2);padding:0.5rem 1.5rem;transition:all 0.3s;}
.f-back:hover{color:var(--gold);border-color:var(--gold);}
</style>
</head>
<body>
<nav>
  <a class="nav-logo" href="/">
    <div class="nav-emblem">慧</div>
    <span class="nav-brand">慧陶香坊</span>
  </a>
  <a class="nav-back" href="/">← 返回首頁</a>
</nav>
<div class="hero">
  <span class="hero-eyebrow">HUITAO WELLNESS · 手工藝術珍品</span>
  <h1 class="hero-title">手繪陶瓷刮痧板</h1>
  <div class="hero-rule"><div class="rl"></div><div class="dot"></div><div class="rl"></div></div>
  <p class="hero-sub">療癒身心 · 讓生活回歸平衡<br>每件作品皆由許朱慧老師純手繪，獨一無二</p>
  <div class="hero-artist">
    <div>
      <div class="hero-artist-name">許朱慧</div>
      <div class="hero-artist-sub">慧陶香坊創辦人｜HUITAO WELLNESS</div>
    </div>
  </div>
</div>
<div class="filter-section">
  <span class="filter-label">系列</span>
  <button class="fb active" onclick="filter('all',this)">全部 18 件</button>
  <button class="fb" onclick="filter('blue',this)">藍牡丹系列</button>
  <button class="fb" onclick="filter('red',this)">紅牡丹系列</button>
  <button class="fb" onclick="filter('orchid',this)">蘭花系列</button>
</div>
<div class="shop-section">
  <div class="sec-wrap">
    <div class="sec-info">
      <span class="sec-title-sm" id="st">全系列作品</span>
      <span class="sec-count" id="sc">共 18 件</span>
    </div>
    <div class="grid" id="grid"></div>
  </div>
</div>
<footer>
  <div class="f-brand">慧陶香坊</div>
  <div class="f-note">純手繪 · 每件獨一無二 · 私訊洽詢訂購<br>HUITAO WELLNESS · 許朱慧 創作</div>
  <a class="f-back" href="/">← 返回慧陶香坊首頁</a>
</footer>
<div class="overlay" id="overlay" onclick="closeModal(event)">
  <div class="modal" id="modal"></div>
</div>
<script>
const CARDS=[{"code": "011", "name": "幸福紅牡丹", "series": "red", "seal": "幸福", "tassel": "粉", "thumb": "", "front": "", "back": ""}, {"code": "012", "name": "吉祥紅牡丹", "series": "red", "seal": "吉祥", "tassel": "粉", "thumb": "", "front": "", "back": ""}, {"code": "013", "name": "喜樂紅牡丹", "series": "red", "seal": "喜樂", "tassel": "粉", "thumb": "", "front": "", "back": ""}, {"code": "014", "name": "如意紅牡丹", "series": "red", "seal": "如意", "tassel": "粉", "thumb": "", "front": "", "back": ""}, {"code": "015", "name": "如意紅牡丹", "series": "red", "seal": "如意", "tassel": "綠", "thumb": "", "front": "", "back": ""}];
const CONCEPTS={"001": {"title": "《幸福藍牡丹》", "text": "幸福，不是擁有多少，<br>而是內心依然保有綻放的力量。<br><br>以盛開牡丹象徵人生的豐盛，<br>藍綠色調代表平靜與療癒，<br>願每一次刮痧舒緩時，<br>都能將幸福與祝福，<br>慢慢帶回自己的心裡。", "deco": "福", "fn": "幸福牡丹 · 藍綠花開", "bn": "幸運印記 · 慧陶香坊"}, "002": {"title": "《平安藍牡丹》", "text": "平安，是送給自己最好的禮物，<br>也是給所愛之人最深的祝願。<br><br>以牡丹的盛放，象徵生命的圓滿，<br>藍綠色調如靜水深流，<br>沉澱浮躁，撫慰疲憊的身心。<br>願每一次輕輕刮過的痕跡，<br>都帶走一份憂慮，留下一份平安。", "deco": "安", "fn": "牡丹花開 · 平安印記", "bn": "慧陶印記 · 好握好施力"}, "003": {"title": "《平安幸福》", "text": "平安，是最深的祝福，<br>幸福，是最真的心願。<br><br>一朵藍牡丹，靜靜綻放，<br>帶著「平安」與「幸福」兩個字，<br>願每一次握在手心的溫度，<br>都能提醒自己——你所擁有的，已是珍貴。", "deco": "福", "fn": "幸福牡丹 · 滿心祝福", "bn": "平安印記 · 慧陶香坊"}, "004": {"title": "《自在牡丹》", "text": "自在，不是無所牽掛，<br>而是在紛擾中，依然能回到自己。<br><br>藍牡丹以豐盛之姿靜靜盛開，<br>紅棕秋葉相伴，訴說歲月的從容，<br>願每一次刮痧的當下，<br>都是給自己的一段自在時光。", "deco": "在", "fn": "自在牡丹 · 從容綻放", "bn": "慧陶印記 · 好握好施力"}, "005": {"title": "《幸福紅牡丹》", "text": "紅，是生命中最熱烈的顏色，<br>是愛，是勇氣，是滿懷的幸福。<br><br>以熱情奔放的紅牡丹，<br>訴說生命中那些值得珍藏的時刻，<br>願每一次刮痧的溫熱，<br>都喚醒身體深處的活力。", "deco": "福", "fn": "紅牡丹盛開 · 平安印記", "bn": "慧陶印記 · 好握好施力"}, "006": {"title": "《幸福紅牡丹》", "text": "幸福，不需要理由，<br>只需要一顆願意感受的心。<br><br>以熱情奔放的紅牡丹，<br>訴說生命中那些值得珍藏的時刻，<br>願每一次刮痧的溫熱，<br>都讓美好，在指尖悄悄流動。", "deco": "福", "fn": "幸福牡丹 · 熱情盛放", "bn": "慧陶印記 · 好握好施力"}, "007": {"title": "《如意紅牡丹》", "text": "如意，是心之所向，皆能成真。<br><br>金黃枝蔓與紅牡丹相映生輝，<br>象徵順遂與圓滿，<br>願每一次輕柔刮拭，<br>都為身體注入如意的能量，<br>讓生活，事事如心所願。", "deco": "意", "fn": "如意牡丹 · 金枝蜿蜒", "bn": "慧陶印記 · 好握好施力"}, "008": {"title": "《幸福紅牡丹》", "text": "幸福，藏在每一個平凡的當下，<br>藏在每一次深呼吸的空隙裡。<br><br>紅牡丹與水墨枝葉相伴，<br>剛柔並濟，豐盛而沉靜，<br>願每一次療癒的時光，<br>都讓幸福，緩緩回到你身邊。", "deco": "福", "fn": "幸福牡丹 · 墨葉相伴", "bn": "慧陶印記 · 好握好施力"}, "009": {"title": "《如意紅牡丹》", "text": "吉祥，是天地給予最溫柔的祝福，<br>如意，是心靈最深處的期盼。<br><br>以盛開的紅牡丹承載美好祈願，<br>花瓣層疊，寓意福澤綿延，<br>願每一次刮痧的當下，<br>都帶來吉祥如意的好兆頭。", "deco": "祥", "fn": "吉祥牡丹 · 富麗盛開", "bn": "慧陶印記 · 好握好施力"}, "010": {"title": "《吉祥紅牡丹》", "text": "吉祥，是歲月最美的禮物，<br>是每一個清晨醒來的平安。<br><br>紅牡丹於翠葉間怒放，<br>金黃點綴，富貴吉慶，<br>願每一次舒緩的刮痧，<br>都為您帶來吉祥如意、萬事順遂。", "deco": "吉", "fn": "吉祥牡丹 · 翠葉環抱", "bn": "慧陶印記 · 好握好施力"}, "011": {"title": "《幸福紅牡丹》", "text": "幸福，是送給自己的溫柔，<br>是願意好好照顧自己的那份心意。<br><br>粉色流蘇輕搖，如幸福悄悄降臨，<br>紅牡丹熱情綻放，訴說圓滿與喜悅，<br>願每一次握住它的當下，<br>都感受到被幸福溫柔包圍的美好。", "deco": "福", "fn": "幸福牡丹 · 附粉色流蘇", "bn": "慧陶印記 · 好握好施力"}, "012": {"title": "《吉祥紅牡丹》", "text": "吉祥，不只是一個詞，<br>更是一種生活的態度與期盼。<br><br>粉色流蘇為作品添上柔美氣息，<br>紅牡丹金枝相映，吉慶富貴，<br>願每一次使用，<br>都為身心帶來吉祥的祝福與能量。", "deco": "祥", "fn": "吉祥牡丹 · 附粉色流蘇", "bn": "慧陶印記 · 好握好施力"}, "013": {"title": "《喜樂紅牡丹》", "text": "喜樂，是心裡最純粹的狀態，<br>不需要理由，只要此刻安好。<br><br>牡丹以淡雅姿態靜靜綻放，<br>粉色流蘇如歡喜搖曳，<br>願每一次刮痧的輕柔觸感，<br>都喚起內心那份純粹而真實的喜樂。", "deco": "喜", "fn": "喜樂牡丹 · 附粉色流蘇", "bn": "慧陶印記 · 好握好施力"}, "014": {"title": "《如意紅牡丹》", "text": "如意，是最溫暖的祝願，<br>願你所思所想，皆能如願以償。<br><br>粉色流蘇搖曳，柔美而優雅，<br>紅牡丹傲然盛開，寓意心想事成，<br>願這一份如意，<br>隨著每一次療癒，輕輕傳遞給你。", "deco": "意", "fn": "如意牡丹 · 附粉色流蘇", "bn": "慧陶印記 · 好握好施力"}, "015": {"title": "《如意紅牡丹》", "text": "如意，如春風吹過，<br>帶走疲憊，留下生機與盼望。<br><br>綠色流蘇清新自然，象徵生命力，<br>搭配紅牡丹的熱情，剛柔相濟，<br>願每一次使用這件作品，<br>都感受到大自然的療癒力量。", "deco": "意", "fn": "如意牡丹 · 附綠色流蘇", "bn": "慧陶印記 · 好握好施力"}, "016": {"title": "《自在蘭花》", "text": "自在，是不被世事束縛的靈魂，<br>是在喧囂中，仍能找到內心的靜土。<br><br>藍蘭花以水墨筆意輕描，<br>一抹清幽，訴說君子之風，<br>願每一次刮痧的當下，<br>都能放下紛擾，回到那個自在的自己。", "deco": "蘭", "fn": "自在蘭花 · 清雅脫俗", "bn": "慧陶印記 · 好握好施力"}, "017": {"title": "《報歲蘭花》", "text": "報歲蘭，是春天最早的使者，<br>在歲末年初悄然綻放，報告新年的到來。<br><br>惜福，是懂得感恩所擁有的一切，<br>珍惜每一個平凡而美好的當下。<br>願每一次握持這件作品，<br>都提醒自己——當下即是福。", "deco": "蘭", "fn": "報歲蘭 · 歲歲報春", "bn": "惜福印記 · 好握好施力"}, "018": {"title": "《幸福藍牡丹》", "text": "幸福，有時是一種感覺，<br>有時是一種選擇，<br>而更多時候，是一種值得珍惜的緣分。<br><br>以潑墨寫意手法揮灑藍牡丹，<br>墨色自由流淌，如幸福本身——<br>不必刻意，願這份幸運與幸福，<br>隨著每一次療癒，輕輕傳遞給您。", "deco": "牡", "fn": "幸福牡丹 · 潑墨寫意", "bn": "幸運印記 · 慧陶香坊"}};
const SL={all:'全系列作品',blue:'藍牡丹系列',red:'紅牡丹系列',orchid:'蘭花系列'};

function buildGrid(s){
  const g=document.getElementById('grid');
  g.innerHTML='';
  const fd=s==='all'?CARDS:CARDS.filter(a=>a.series===s);
  document.getElementById('st').textContent=SL[s];
  document.getElementById('sc').textContent='共 '+fd.length+' 件';
  fd.forEach(function(a){
    const t=a.tassel?'<div class="card-tassel-badge">🎀 '+a.tassel+'色流蘇</div>':'';
    const d=document.createElement('div');
    d.className='card';
    d.onclick=function(){openModal(a.code);};
    d.innerHTML='<div class="card-img-wrap">'
      +'<img class="card-img" src="data:image/jpeg;base64,'+a.thumb+'" alt="'+a.name+'">'
      +'<div class="card-overlay"><span>查看詳情</span></div>'
      +'<div class="card-seal">'+a.seal+'</div>'+t
      +'</div><div class="card-body">'
      +'<div class="card-cat">手繪陶瓷 · 刮痧板</div>'
      +'<div class="card-name">'+a.name+'</div>'
      +'<div class="card-code">HTP-'+a.code+'</div>'
      +'</div><div class="card-footer">'
      +'<span class="card-price">NT$ 1,200</span>'
      +'<span class="card-btn">查看詳情 →</span>'
      +'</div>';
    g.appendChild(d);
  });
}

function filter(s,btn){
  document.querySelectorAll('.fb').forEach(function(b){b.classList.remove('active');});
  btn.classList.add('active');
  buildGrid(s);
}

function openModal(code){
  const a=CARDS.find(function(x){return x.code===code;});
  const c=CONCEPTS[code];
  const frontSrc='data:image/jpeg;base64,'+a.front;
  const backSrc='data:image/jpeg;base64,'+a.back;
  const t=a.tassel?'<div class="m-tassel">🎀 附贈'+a.tassel+'色流蘇繩</div>':'';
  const ts=a.tassel?'<div class="m-sr"><span class="m-sk">附件</span><span class="m-sv">附贈'+a.tassel+'色流蘇繩</span></div>':'';
  const html=
    '<div class="m-top"><span class="m-top-b">慧陶香坊</span><div class="m-top-actions"><span class="m-top-e">HUITAO WELLNESS</span><button class="m-top-close" type="button" aria-label="關閉商品詳情" onclick="closeModal()">×</button></div></div>'
    +'<div class="m-photos">'
    +'<div class="m-photo"><div class="m-photo-frame"><img src="'+frontSrc+'" alt="正面"></div>'
    +'<span class="m-photo-label">正 面</span><span class="m-photo-note">'+c.fn+'</span></div>'
    +'<div class="m-photo"><div class="m-photo-frame"><img src="'+backSrc+'" alt="背面"></div>'
    +'<span class="m-photo-label">背 面</span><span class="m-photo-note">'+c.bn+'</span></div>'
    +'</div>'
    +'<div class="m-body">'
    +'<div class="m-code">手繪陶瓷刮痧板 · HTP-'+a.code+'</div>'
    +'<div class="m-title-row"><h2 class="m-title">'+a.name+'</h2>'
    +'<div class="m-pb"><div class="m-pl">訂購價格</div><div class="m-pv">NT$ 1,200</div><div class="m-pn">純手繪·限量珍藏</div></div></div>'
    +'<div class="m-sub">一器多用 · 療癒身心 · 讓生活回歸平衡</div>'+t
    +'<div class="m-artist"><div class="m-av">慧</div><div>'
    +'<div class="m-al">創 作 者</div><div class="m-an">許朱慧</div>'
    +'<div class="m-as">慧陶香坊創辦人｜HUITAO WELLNESS</div></div></div>'
    +'<div class="m-con"><div class="m-cd">'+c.deco+'</div>'
    +'<div class="m-cl">創 作 理 念</div><div class="m-ct">'+c.title+'</div>'
    +'<div class="m-cx">'+c.text+'</div></div>'
    +'<div class="m-det"><div><div class="m-sl">規 格</div><div class="m-sps">'
    +'<div class="m-sr"><span class="m-sk">尺寸</span><span class="m-sv">約 10×6 cm</span></div>'
    +'<div class="m-sr"><span class="m-sk">材質</span><span class="m-sv">高溫陶瓷</span></div>'
    +'<div class="m-sr"><span class="m-sk">工藝</span><span class="m-sv">釉上手繪彩</span></div>'
    +ts
    +'<div class="m-sr"><span class="m-sk">數量</span><span class="m-sv">限量·獨一無二</span></div>'
    +'</div></div><div><div class="m-sl">功效與用途</div><div class="m-tags">'
    +'<span class="m-tag">疏通經絡</span><span class="m-tag">促進循環</span>'
    +'<span class="m-tag">舒緩筋膜</span><span class="m-tag">美顏提升</span>'
    +'<span class="m-tag">療癒身心</span><span class="m-tag">回歸平衡</span>'
    +'</div></div></div></div>'
    +'<div class="m-foot"><span class="m-fb">慧陶香坊</span>'
    +'<span class="m-fn">純手繪·私訊洽詢訂購</span>'
    +'<div class="m-fs">'+a.seal+'</div></div>'
    +'<button class="m-close" onclick="closeModal()">關 閉</button>';
  document.getElementById('modal').innerHTML=html;
  document.getElementById('overlay').classList.add('open');
}

function closeModal(e){
  if(!e||e.target===document.getElementById('overlay')){
    document.getElementById('overlay').classList.remove('open');
  }
}

Object.assign(window,{filter,openModal,closeModal});
buildGrid('all');
</script>
</body>
</html>
