<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>慧陶香企業社｜東方身心靈療癒品牌｜許朱慧</title>
<meta name="description" content="慧陶香企業社，創辦人許朱慧，結合聲缽療癒、太極養生、香療、陶瓷彩繪，打造東方身心靈療癒品牌。MedCoral珊瑚精靈授權經銷商。台灣療癒課程、陶瓷彩繪商品。">
<meta name="keywords" content="慧陶香企業社,慧陶香坊,許朱慧,聲缽療癒,頌缽療癒,太極養生,靜心香療,陶瓷彩繪,刮痧板,茶組,MedCoral,珊瑚精靈,珊瑚活力精華液,身心靈療癒,東方療癒,台灣療癒,板橋療癒">
<meta name="author" content="慧陶香企業社 許朱慧">
<meta property="og:title" content="慧陶香企業社｜東方身心靈療癒品牌">
<meta property="og:description" content="融合藝術・養生療癒・生活美學，打造東方身心靈療癒品牌。聲缽療癒、太極養生、香療課程，陶瓷彩繪商品，MedCoral珊瑚精靈授權經銷。">
<meta property="og:type" content="website">
<meta property="og:url" content="https://huitao.tw/">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@300;400;600;700&family=Noto+Sans+TC:wght@300;400;500&display=swap" rel="stylesheet">
<style is:global>
:root{
  --gold:#c9a84c;--gold-light:#e2c97e;--gold-pale:#f5e9c8;
  --cream:#faf7f0;--parchment:#f0e8d5;
  --ink:#1a1612;--ink-soft:#2e2620;
  --red:#7a2020;--red-light:#9b3030;
  --gray-ink:#8c8278;--border-gold:rgba(201,168,76,0.3);
  --serif:'Noto Serif TC',serif;--sans:'Noto Sans TC',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--cream);color:var(--ink);font-family:var(--serif);overflow-x:hidden;}

/* NAVBAR */
nav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  background:rgba(250,247,240,0.97);
  border-bottom:1px solid var(--border-gold);
  backdrop-filter:blur(12px);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 4rem;height:68px;
  transition:background 0.4s,box-shadow 0.4s;
}
nav.scrolled{background:rgba(250,247,240,0.82);box-shadow:0 2px 30px rgba(28,20,8,0.08);}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.nav-emblem{
  width:36px;height:36px;border:1.5px solid var(--gold);border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;color:var(--gold);font-weight:700;
}
.nav-brand{font-size:1.05rem;font-weight:700;color:var(--gold);letter-spacing:0.15em;}
.nav-links{display:flex;gap:2.2rem;list-style:none;}
.nav-links a{
  color:var(--ink);text-decoration:none;font-family:var(--sans);
  font-size:0.82rem;font-weight:400;letter-spacing:0.12em;transition:color 0.3s;position:relative;
}
.nav-links a::after{
  content:'';position:absolute;bottom:-3px;left:0;right:0;
  height:1px;background:var(--gold);transform:scaleX(0);transition:transform 0.3s;
}
.nav-links a:hover{color:var(--gold);}
.nav-links a:hover::after{transform:scaleX(1);}

/* HERO */
.hero{min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;background:#f5ede0;}
.hero-bg-img{
  position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;z-index:0;
}
.hero-overlay{
  position:absolute;inset:0;z-index:1;
  background:linear-gradient(to right,
    rgba(248,242,232,0.98) 0%,
    rgba(248,242,232,0.95) 28%,
    rgba(248,242,232,0.72) 46%,
    rgba(248,242,232,0.18) 62%,
    transparent 76%);
}
.hero-content{
  position:relative;z-index:2;
  padding:2rem 2rem 2rem 6vw;
  max-width:500px;
  animation:heroIn 1.6s cubic-bezier(0.22,1,0.36,1) forwards;
}
@keyframes heroIn{from{opacity:0;transform:translateY(36px);}to{opacity:1;transform:translateY(0);}}
.hero-eyebrow{
  font-family:var(--sans);font-size:0.7rem;font-weight:400;
  letter-spacing:0.45em;color:#a07830;margin-bottom:1.6rem;display:block;
  text-shadow:0 1px 6px rgba(248,242,232,0.9);
}
.hero-title{
  font-size:clamp(1.8rem,3.6vw,2.9rem);font-weight:700;
  color:#3a2e1e;letter-spacing:0.18em;line-height:1.35;
  margin-bottom:0.8rem;white-space:nowrap;
  text-shadow:0 2px 16px rgba(245,237,224,0.9);
}
.hero-divider{display:flex;align-items:center;gap:0.8rem;margin:1.4rem 0;}
.hero-divider .hl{width:60px;height:1px;background:linear-gradient(to right,transparent,var(--gold));}
.hero-divider .hl.r{background:linear-gradient(to left,transparent,var(--gold));}
.hero-divider .dia{width:7px;height:7px;border:1px solid var(--gold);transform:rotate(45deg);}
.hero-sub{
  font-family:var(--sans);font-size:0.93rem;font-weight:500;
  color:rgba(50,35,10,0.88);letter-spacing:0.1em;line-height:1.9;
  margin-bottom:0.6rem;text-shadow:0 1px 8px rgba(248,242,232,0.95);
}
.hero-sub2{
  font-family:var(--sans);font-size:0.78rem;font-weight:300;
  color:rgba(60,45,15,0.68);letter-spacing:0.08em;line-height:1.85;
  margin-bottom:2.4rem;text-shadow:0 1px 6px rgba(248,242,232,0.9);
}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap;}
.btn-gold{
  padding:0.82rem 2rem;background:var(--gold);border:none;
  color:var(--ink);font-family:var(--serif);font-size:0.86rem;font-weight:600;
  letter-spacing:0.25em;cursor:pointer;text-decoration:none;transition:all 0.3s;
}
.btn-gold:hover{background:var(--gold-light);transform:translateY(-2px);box-shadow:0 8px 24px rgba(201,168,76,0.35);}
.btn-outline{
  padding:0.82rem 2rem;background:transparent;
  border:1px solid rgba(100,75,20,0.45);
  color:rgba(70,50,15,0.82);font-family:var(--sans);font-size:0.82rem;font-weight:300;
  letter-spacing:0.2em;cursor:pointer;text-decoration:none;transition:all 0.3s;
}
.btn-outline:hover{border-color:var(--gold);color:var(--gold);}
.scroll-hint{
  position:absolute;bottom:2rem;left:6vw;z-index:3;
  display:flex;flex-direction:column;gap:5px;
  color:rgba(120,90,30,0.5);font-family:var(--sans);font-size:0.58rem;letter-spacing:0.35em;
  animation:scrollBob 2.2s ease-in-out infinite;
}
@keyframes scrollBob{0%,100%{opacity:0.35;transform:translateY(0);}50%{opacity:0.7;transform:translateY(7px);}}

/* SHARED */
.sec-wrap{max-width:1200px;margin:0 auto;padding:0 2rem;}
.sec-eyebrow{display:block;font-family:var(--sans);font-size:0.65rem;font-weight:300;letter-spacing:0.55em;color:var(--gold);text-transform:uppercase;margin-bottom:0.9rem;}
.sec-title{font-size:clamp(1.6rem,3.5vw,2.4rem);font-weight:600;letter-spacing:0.18em;color:var(--ink);}
.sec-rule{display:flex;align-items:center;gap:0.7rem;margin-top:1rem;}
.sec-rule .rl{height:1px;background:var(--gold);}
.sec-rule .rl.lg{width:55px;}.sec-rule .rl.sm{width:18px;}
.sec-rule .dot{width:5px;height:5px;border-radius:50%;background:var(--gold);}
.sec-center{text-align:center;}.sec-center .sec-rule{justify-content:center;}
.fade{opacity:0;transform:translateY(24px);transition:opacity 0.85s ease,transform 0.85s ease;}
.fade.in{opacity:1;transform:none;}

/* ABOUT */
.about{padding:9rem 2rem;background:var(--cream);}
.about-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1.15fr;gap:5rem;align-items:center;}
.about-photo-wrap{position:relative;}
.about-photo{
  width:100%;aspect-ratio:3/4;object-fit:cover;object-position:top center;
  border:1px solid var(--border-gold);display:block;
}
.about-frame-corner{position:absolute;width:18px;height:18px;border-color:var(--gold);border-style:solid;}
.about-frame-corner.tl{top:-5px;left:-5px;border-width:2px 0 0 2px;}
.about-frame-corner.tr{top:-5px;right:-5px;border-width:2px 2px 0 0;}
.about-frame-corner.bl{bottom:-5px;left:-5px;border-width:0 0 2px 2px;}
.about-frame-corner.br{bottom:-5px;right:-5px;border-width:0 2px 2px 0;}
.about-badge{
  position:absolute;top:-18px;right:-18px;width:82px;height:82px;
  background:var(--red);border-radius:50%;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  border:3px solid var(--gold-pale);box-shadow:0 6px 20px rgba(122,32,32,0.3);
}
.about-badge .bn{font-size:1.3rem;font-weight:700;color:var(--gold-pale);line-height:1;}
.about-badge .bu{font-family:var(--sans);font-size:0.55rem;color:rgba(245,233,200,0.8);letter-spacing:0.1em;margin-top:2px;}
.about-text .sec-title,.about-text .sec-eyebrow{text-align:left;}
.about-text .sec-rule{justify-content:flex-start;}
.about-body{font-family:var(--sans);font-size:0.92rem;font-weight:300;color:var(--gray-ink);line-height:2.2;margin:1.8rem 0 1.6rem;}
.about-quote{padding:1.4rem 1.5rem;background:var(--parchment);border-left:3px solid var(--gold);margin-bottom:1.8rem;}
.about-quote strong{display:block;font-family:var(--serif);font-size:0.88rem;font-weight:600;color:var(--ink);letter-spacing:0.1em;margin-bottom:0.5rem;}
.about-quote p{font-family:var(--sans);font-size:0.8rem;font-weight:300;color:var(--ink-soft);line-height:1.9;}
.about-certs{display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.5rem;}
.cert-tag{padding:0.25rem 0.8rem;border:1px solid var(--border-gold);font-family:var(--sans);font-size:0.68rem;font-weight:300;color:var(--gold);letter-spacing:0.12em;}
.about-links{display:flex;gap:1rem;flex-wrap:wrap;}

/* SHOP */
.shop{padding:9rem 2rem;background:var(--parchment);position:relative;}
.shop::before,.shop::after{content:'';position:absolute;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--gold),transparent);}
.shop::before{top:0;}.shop::after{bottom:0;}
.shop-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.8rem;margin-top:3.5rem;}
.product-card{background:var(--cream);border:1px solid var(--border-gold);display:flex;flex-direction:column;overflow:hidden;transition:transform 0.4s,box-shadow 0.4s;}
.product-card:hover{transform:translateY(-8px);box-shadow:0 24px 50px rgba(28,20,8,0.12);}
.product-img-wrap{position:relative;overflow:hidden;aspect-ratio:4/3;background:#f0ece4;}
.product-img-wrap img{width:100%;height:100%;object-fit:cover;object-position:center;transition:transform 0.6s ease;}
.product-card:hover .product-img-wrap img{transform:scale(1.06);}
.p-overlay{position:absolute;inset:0;background:rgba(26,22,18,0.6);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.4s;}
.product-card:hover .p-overlay{opacity:1;}
.p-overlay span{color:var(--gold-pale);font-family:var(--sans);font-size:0.75rem;letter-spacing:0.3em;border:1px solid var(--gold);padding:0.5rem 1.3rem;}
.product-body{padding:1.4rem;flex:1;display:flex;flex-direction:column;gap:0.5rem;}
.product-cat{font-family:var(--sans);font-size:0.62rem;color:var(--gold);letter-spacing:0.35em;text-transform:uppercase;}
.product-name{font-size:1rem;font-weight:600;letter-spacing:0.08em;color:var(--ink);line-height:1.4;}
.product-desc{font-family:var(--sans);font-size:0.8rem;font-weight:300;color:var(--gray-ink);line-height:1.8;flex:1;}
.product-feats{display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:0.4rem;}
.p-feat{font-family:var(--sans);font-size:0.64rem;font-weight:300;color:var(--red);border:1px solid rgba(122,32,32,0.22);padding:0.15rem 0.6rem;letter-spacing:0.08em;}
.product-footer{padding:1rem 1.4rem;border-top:1px solid var(--border-gold);display:flex;align-items:center;justify-content:space-between;}
.btn-detail{font-family:var(--sans);font-size:0.75rem;font-weight:300;color:var(--gold);letter-spacing:0.2em;text-decoration:none;cursor:pointer;background:none;border:none;transition:letter-spacing 0.3s;}
.product-card:hover .btn-detail{letter-spacing:0.3em;}

/* WELLNESS */
.wellness{padding:9rem 2rem;background:var(--cream);}
.wellness-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:3.5rem;}
.course-card{background:#fff;border:1px solid var(--border-gold);overflow:hidden;display:flex;flex-direction:column;transition:transform 0.4s,box-shadow 0.4s;}
.course-card:hover{transform:translateY(-8px);box-shadow:0 20px 45px rgba(28,20,8,0.1);}
.course-img-wrap{position:relative;overflow:hidden;aspect-ratio:16/9;background:#e8e0d0;}
.course-img-wrap img{width:100%;height:100%;object-fit:cover;object-position:center;transition:transform 0.6s;}
.course-card:hover .course-img-wrap img{transform:scale(1.06);}
.course-img-icon{
  width:100%;height:100%;display:flex;align-items:center;justify-content:center;
  font-size:3rem;
}
.course-body{padding:1.6rem 1.5rem;flex:1;display:flex;flex-direction:column;gap:0.6rem;}
.course-tag{font-family:var(--sans);font-size:0.62rem;color:var(--gold);letter-spacing:0.4em;text-transform:uppercase;}
.course-name{font-size:1.05rem;font-weight:600;letter-spacing:0.12em;color:var(--ink);}
.course-theme{display:inline-block;font-family:var(--sans);font-size:0.7rem;font-weight:300;color:var(--red-light);border:1px solid rgba(122,32,32,0.2);padding:0.2rem 0.7rem;letter-spacing:0.15em;margin-bottom:0.3rem;}
.course-desc{font-family:var(--sans);font-size:0.82rem;font-weight:300;color:var(--gray-ink);line-height:1.85;flex:1;}
.course-footer{padding:1.2rem 1.5rem;border-top:1px solid var(--border-gold);}
.btn-book{width:100%;padding:0.75rem;background:transparent;border:1px solid var(--gold);color:var(--gold);font-family:var(--serif);font-size:0.82rem;letter-spacing:0.3em;cursor:pointer;transition:all 0.35s;position:relative;overflow:hidden;}
.btn-book::before{content:'';position:absolute;inset:0;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform 0.35s;z-index:-1;}
.btn-book:hover{color:var(--ink);}.btn-book:hover::before{transform:scaleX(1);}

/* GALLERY */
.gallery{padding:9rem 2rem;background:var(--parchment);position:relative;}
.gallery::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--gold),transparent);}
.gallery-grid{display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:220px 220px;gap:1rem;margin-top:3.5rem;}
.gallery-item{overflow:hidden;position:relative;cursor:pointer;border:1px solid var(--border-gold);background:var(--parchment);}
.gallery-item:first-child{grid-column:span 2;grid-row:span 2;}
.gallery-item img{width:100%;height:100%;object-fit:cover;object-position:center;transition:transform 0.6s ease;}
.gallery-item:hover img{transform:scale(1.08);}
.gallery-item .g-overlay{position:absolute;inset:0;background:rgba(26,22,18,0);display:flex;align-items:flex-end;padding:1rem;transition:background 0.4s;}
.gallery-item:hover .g-overlay{background:rgba(26,22,18,0.45);}
.g-label{font-family:var(--sans);font-size:0.72rem;font-weight:300;color:var(--gold-pale);letter-spacing:0.25em;opacity:0;transform:translateY(8px);transition:all 0.4s;}
.gallery-item:hover .g-label{opacity:1;transform:none;}
.gallery-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:3rem;background:linear-gradient(135deg,var(--parchment),#d8c8a8);}

/* LINE CTA */
.line-cta{padding:7rem 2rem;background:var(--cream);text-align:center;position:relative;overflow:hidden;border-top:1px solid var(--border-gold);}
.line-cta::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 70% at 50% 50%,rgba(201,168,76,0.06) 0%,transparent 65%);}
.line-cta-inner{position:relative;z-index:1;}
.line-cta-eyebrow{font-family:var(--sans);font-size:0.75rem;letter-spacing:0.55em;color:var(--gold);text-transform:uppercase;margin-bottom:1.2rem;display:block;}
.line-cta-title{font-size:clamp(1.8rem,4vw,3rem);font-weight:700;color:var(--ink);letter-spacing:0.2em;margin-bottom:1rem;}
.line-cta-desc{font-family:var(--sans);font-size:1rem;font-weight:300;color:var(--gray-ink);letter-spacing:0.1em;line-height:2;max-width:480px;margin:0 auto 3rem;}
.btn-line-cta{display:inline-flex;align-items:center;gap:10px;padding:1rem 2.8rem;background:var(--gold);color:var(--ink);font-family:var(--serif);font-size:0.95rem;font-weight:600;letter-spacing:0.25em;text-decoration:none;transition:all 0.3s;}
.btn-line-cta:hover{background:var(--gold-light);transform:translateY(-3px);box-shadow:0 10px 30px rgba(201,168,76,0.35);}

/* FOOTER */
footer{background:#0c0a07;padding:4rem 2rem 2.5rem;border-top:1px solid rgba(201,168,76,0.15);}
.footer-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr 1fr;gap:3rem;align-items:start;}
.footer-brand .fb-logo{display:flex;align-items:center;gap:10px;margin-bottom:1rem;text-decoration:none;}
.fb-emblem{width:34px;height:34px;border:1.5px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.9rem;color:var(--gold);}
.fb-name{font-size:0.95rem;font-weight:700;color:var(--gold);letter-spacing:0.15em;}
.footer-brand p{font-family:var(--sans);font-size:0.72rem;color:rgba(245,233,200,0.72);letter-spacing:0.2em;line-height:1.8;}
.footer-col h4{font-size:0.78rem;font-weight:600;color:#fff3cf;letter-spacing:0.25em;margin-bottom:1.2rem;}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:0.7rem;}
.footer-col ul li,.footer-col ul li a{font-family:var(--sans);font-size:0.78rem;font-weight:300;color:rgba(226,201,126,0.82);letter-spacing:0.1em;text-decoration:none;transition:color 0.3s;}
.footer-col ul li a:hover{color:#fff0bf;}
.footer-social{display:flex;gap:0.8rem;margin-top:1rem;}
.social-btn{width:34px;height:34px;border:1px solid rgba(201,168,76,0.3);display:flex;align-items:center;justify-content:center;font-size:0.85rem;color:rgba(201,168,76,0.5);text-decoration:none;transition:all 0.3s;font-family:var(--sans);}
.social-btn:hover{border-color:var(--gold);color:var(--gold);}
.footer-bottom{max-width:1100px;margin:3rem auto 0;padding-top:2rem;border-top:1px solid rgba(201,168,76,0.1);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;}
.footer-bottom span{font-family:var(--sans);font-size:0.65rem;color:rgba(226,201,126,0.58);letter-spacing:0.2em;}

@media(max-width:900px){
  nav{padding:0 1.5rem;}.nav-links{display:none;}
  .about-inner{grid-template-columns:1fr;gap:2.5rem;}
  .shop-grid{grid-template-columns:1fr;}
  .wellness-grid{grid-template-columns:1fr;}
  .gallery-grid{grid-template-columns:1fr 1fr;grid-template-rows:auto;}
  .gallery-item:first-child{grid-column:span 2;grid-row:span 1;height:220px;}
  .footer-inner{grid-template-columns:1fr;}
  .hero-title{white-space:normal;}
}
</style>
</head>
<body>

<nav id="mainNav">
  <a href="#hero" class="nav-logo">
    <div class="nav-emblem">香</div>
    <div style="display:flex;flex-direction:column;gap:1px;">
      <span class="nav-brand">慧陶香坊</span>
      <span style="font-family:var(--sans);font-size:0.6rem;font-weight:300;color:rgba(201,168,76,0.6);letter-spacing:0.12em;">Huitao Xiangfang</span>
    </div>
  </a>
  <ul class="nav-links">
    <li><a href="#hero">首頁</a></li>
    <li><a href="#about">品牌理念</a></li>
    <li><a href="#shop">商品選物</a></li>
    <li><a href="#wellness">課程體驗</a></li>
    <li><a href="#gallery">藝術創作</a></li>
    <li><a href="#contact">聯絡我們</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero" id="hero">
  <img class="hero-bg-img" src="data:image/jpeg;base64," alt="慧陶香坊">
  <div class="hero-overlay"></div>
