---
import Layout from '../layouts/Layout.astro';
---

<Layout title="線上預約">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 pb-32">
    <div class="text-center mb-16">
      <h1 class="text-4xl font-bold text-gray-900 mb-4 tracking-wider">線上預約</h1>
      <p class="text-xl text-gray-500 max-w-2xl mx-auto mb-6">歡迎預約我們的手作課程或現場選購導覽</p>
      <div class="w-16 h-1 bg-brand-500 mx-auto rounded-full"></div>
    </div>

    <!-- Booking Form Container -->
    <div class="bg-white rounded-3xl shadow-2xl overflow-hidden mt-12">
      <div class="p-8 md:p-12 text-gray-800">
        <h2 class="text-2xl font-bold mb-8 text-brand-700">填寫您的預約資訊</h2>
        
        <form class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- 姓名 -->
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-2">姓名 <span class="text-red-500">*</span></label>
              <input type="text" id="name" name="name" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all" placeholder="請輸入姓名" required />
            </div>
            
            <!-- 電話 -->
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">電話 <span class="text-red-500">*</span></label>
              <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all" placeholder="請輸入電話" required />
            </div>
          </div>

          <!-- 預約類型 -->
          <div>
            <label for="service" class="block text-sm font-medium text-gray-700 mb-2">預約項目 <span class="text-red-500">*</span></label>
            <select id="service" name="service" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all" required>
              <option value="">請選擇您想體驗的項目</option>
              <option value="basic">捏陶初體驗 (2小時)</option>
              <option value="advanced">拉胚進階班 (3小時)</option>
              <option value="tour">現場參觀導覽</option>
            </select>
          </div>

          <!-- 日期與人數 -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="date" class="block text-sm font-medium text-gray-700 mb-2">預約日期 <span class="text-red-500">*</span></label>
              <input type="date" id="date" name="date" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all" required />
            </div>
            <div>
              <label for="guests" class="block text-sm font-medium text-gray-700 mb-2">參加人數 <span class="text-red-500">*</span></label>
              <input type="number" id="guests" name="guests" min="1" max="10" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all" placeholder="請輸入數量" required />
            </div>
          </div>

          <!-- 備註 -->
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-2">備註事項</label>
            <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all" placeholder="若有特殊需求請先告知"></textarea>
          </div>

          <div class="pt-6">
            <button type="submit" class="w-full bg-brand-600 hover:bg-brand-700 text-white font-bold py-4 rounded-lg text-lg shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-1">
              確認送出預約
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>